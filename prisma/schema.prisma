// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("editor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?
  isActive        Boolean   @default(true)
}

model Page {
  id       Int           @id @default(autoincrement())
  name     String
  slug     String        @unique
  navbar   Boolean       @default(false)
  contents PageContent[]
}

model PageContent {
  id              Int     @id @default(autoincrement())
  pageId          Int
  name            String
  image           String? @db.Text
  mainText        String? @db.Text
  subtext1        String? @db.Text
  subtext2        String? @db.Text
  subtext3        String? @db.Text
  // Stored as JSON arrays/objects
  lists           Json?
  primaryButton   Json?   // { text: string, link: string }
  secondaryButton Json?   // { text: string, link: string }

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model Event {
  id          Int      @id @default(autoincrement())
  category    String
  name        String
  description String   @db.Text
  content     String?  @db.Text
  location    String?
  schedule    String?  @db.Text
  images      Json?    // array of image URLs / objects
  date        DateTime?
  image               String?
  flyer               String?       
  allowRegistration   Boolean       @default(false)
  allowVolunteer      Boolean       @default(false)
  notificationEmail   String?
  volunteersToken     String?       @unique
  volunteerShifts     String?       @db.Text
  volunteersShifts     Json?       
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  signups             EventSignup[]
}

model Resource {
  id          Int     @id @default(autoincrement())
  title       String
  description String  @db.Text
  category    String
  url         String?
  content     String? @db.Text
  file        String? // file path or URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gallery {
  id          Int     @id @default(autoincrement())
  title       String
  category    String
  year        Int
  description String? @db.Text
  images      Json?   // array of image URLs / objects
  heroImage   String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Newsletter {
  id            Int       @id @default(autoincrement())
  title         String
  subtitle      String?
  description   String?   @db.Text
  content       String?    @db.Text
  file          String?    @db.Text
  category      String?
  images        Json?   // array of image URLs / objects
  heroImage     String? @db.Text
  publishedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Member {
  id                Int      @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String   @unique
  phone             String?
  address           String?
  street            String?
  city              String?
  state             String?
  zipcode           String?
  knightYears       String? 
  additionalMessage String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum SignupType {
  REGISTRATION
  VOLUNTEER
}

model EventSignup {
  id        Int          @id @default(autoincrement())
  eventId   Int
  type      SignupType

  firstName String
  lastName  String
  email     String
  phone     String?
  message   String?      @db.Text
  shift     String?      @db.Text
  shifts    Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([email])
  @@index([type])
  @@unique([eventId, email, type])  // one signup per type per person per event
}